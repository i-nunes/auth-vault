{
  "moduleFileExtensions": ["js", "json", "ts"],
  "setupFiles": ["./setup-env.ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverage": true,
  "collectCoverageFrom": ["src/**/*.{js,jsx,ts,tsx}"],
  "coverageThreshold": {
    "global": {
      "statements": 75,
      "branches": 75,
      "functions": 75,
      "lines": 75
    }
  }
}
